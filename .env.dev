# QPP Project Environment Variables - DEVELOPMENT
# Copy this file to .env for local development

# Application
DEBUG=True
APP_NAME=QPP API
APP_VERSION=1.0.0-dev

# Database
POSTGRES_DB=qpp_db
POSTGRES_USER=qpp_user
POSTGRES_PASSWORD=qpp_password
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:9000,http://localhost:8080,http://127.0.0.1:9000,http://127.0.0.1:8080

# Frontend
FRONTEND_PORT=9000

# Nginx
HTTP_PORT=8080
HTTPS_PORT=443
