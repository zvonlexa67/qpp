# QPP Project Environment Variables - PRODUCTION
# Copy this file to .env for production deployment

# Application
DEBUG=False
APP_NAME=QPP API
APP_VERSION=1.0.0

# Database - CHANGE THESE IN PRODUCTION!
POSTGRES_DB=qpp_db
POSTGRES_USER=qpp_user
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=8000
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Frontend
FRONTEND_PORT=9000

# Nginx
HTTP_PORT=80
HTTPS_PORT=443
